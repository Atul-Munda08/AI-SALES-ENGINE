# Copy this file to ".env" and fill in your real values.
# NEVER commit the real ".env" file to git — add it to .gitignore.

# Your Gemini API key. Get/rotate it at https://aistudio.google.com/apikey
# Since a key was pasted into a chat earlier, generate a NEW one and use that here.
GEMINI_API_KEY=

# The model the widget uses. gemini-3.1-flash-lite is the current cost/speed
# optimized "lite" tier — a good fit for a chat widget.
GEMINI_MODEL=gemini-3.1-flash-lite

# Restrict this to your actual landing page domain once you're live, e.g.
# ALLOWED_ORIGIN=https://www.yourlandingpage.com
# Leaving it as * means ANY website could call your backend and spend your
# Gemini quota — fine for local testing, not for production.
ALLOWED_ORIGIN=*

# Optional: customize the assistant's behavior/tone.
SYSTEM_PROMPT=You are a friendly, concise assistant embedded on a SaaS landing page. Answer visitor questions about the product helpfully and briefly (2-4 sentences). If someone shows real interest, invite them to share their email or book a demo. Never invent pricing, features, or facts you were not given.

PORT=3000
